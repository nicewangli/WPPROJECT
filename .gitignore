########################################
# WordPress repo policy (recommended)
# Track only wp-content/, ignore everything else.
########################################

# Ignore everything by default (whitelist strategy)
*

# Allow traversing directories so negation rules work
!*/

# Keep this file tracked
!.gitignore

########################################
# Allow themes (你的主题代码)
########################################
!wp-content/
!wp-content/themes/
!wp-content/themes/**

########################################
# Allow plugins directory but NOT third-party plugin contents
# 如果你以后写自己的插件，取消注释下面两行
########################################
!wp-content/plugins/
!wp-content/mu-plugins/
wp-content/plugins/*/
wp-content/mu-plugins/*/

# 如果你有自己的插件要跟踪，取消注释并改成你的插件名
# !wp-content/plugins/你的插件名/
# !wp-content/plugins/你的插件名/**

########################################
# Runtime / generated content inside wp-content
########################################
wp-content/uploads/
wp-content/cache/
wp-content/upgrade/
wp-content/backups*/
wp-content/*.log

########################################
# OS / Editor (harmless even under whitelist)
########################################
.DS_Store
Thumbs.db
.vscode/
.idea/

########################################
# Local-only/debug
########################################
local-xdebuginfo.php