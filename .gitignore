########################################
# WordPress repo policy (recommended)
# Track only wp-content/, ignore everything else.
########################################

# Ignore everything by default (whitelist strategy)
*

# Allow traversing directories so negation rules work
!*/

# Keep this file tracked
!.gitignore

########################################
# Allow wp-content (themes/plugins/mu-plugins)
########################################
!wp-content/
!wp-content/**

########################################
# Runtime / generated content inside wp-content
########################################
wp-content/uploads/
wp-content/cache/
wp-content/upgrade/
wp-content/backups*/
wp-content/*.log

########################################
# OS / Editor (harmless even under whitelist)
########################################
.DS_Store
Thumbs.db
.vscode/
.idea/

########################################
# Local-only/debug
########################################
local-xdebuginfo.php